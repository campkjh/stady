generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nickname  String
  avatar    String?
  role         String   @default("user")
  signupSource String?
  createdAt    DateTime @default(now())

  attempts  QuizAttempt[]
  bookmarks Bookmark[]
  reviews   Review[]
  studySessions StudySession[]
  communityPosts CommunityPost[]
  communityComments CommunityComment[]
  communityReports CommunityReport[]
  communityPostLikes CommunityPostLike[]
  communityCommentLikes CommunityCommentLike[]
}

model CommunityCategoryGroup {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String   @default("")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tags  CommunityTag[]
  posts CommunityPost[]

  @@map("CommunityCategoryGroup")
}

model CommunityTag {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  name        String
  slug        String
  description String   @default("")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group CommunityCategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  postTags CommunityPostTag[]

  @@unique([groupId, slug])
  @@index([groupId])
  @@map("CommunityTag")
}

model CommunityPost {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  groupId     String   @map("group_id")
  title       String
  content     String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  group CommunityCategoryGroup @relation(fields: [groupId], references: [id])
  postTags CommunityPostTag[]
  images CommunityPostImage[]
  comments CommunityComment[]
  reports CommunityReport[]
  likes CommunityPostLike[]

  @@index([groupId])
  @@index([createdAt])
  @@map("CommunityPost")
}

model CommunityPostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  CommunityTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("CommunityPostTag")
}

model CommunityPostImage {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  imageUrl  String   @map("image_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
  @@map("CommunityPostImage")
}

model CommunityComment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  parentId  String?  @map("parent_id")
  userId    String?  @map("user_id")
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent CommunityComment? @relation("CommunityCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies CommunityComment[] @relation("CommunityCommentReplies")
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  likes CommunityCommentLike[]

  @@index([postId])
  @@index([postId, parentId])
  @@map("CommunityComment")
}

model CommunityPostLike {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@map("CommunityPostLike")
}

model CommunityCommentLike {
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("CommunityCommentLike")
}

model CommunityReport {
  id        String   @id @default(uuid())
  postId    String?  @map("post_id")
  userId    String?  @map("user_id")
  reason    String
  status    String   @default("접수")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post CommunityPost? @relation(fields: [postId], references: [id], onDelete: SetNull)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("CommunityReport")
}

model StudySession {
  id         String    @id @default(uuid())
  userId     String
  subject    String    @default("공부중")
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  lastPingAt DateTime  @default(now())
  totalSeconds Int     @default(0)

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([endedAt])
}

model Category {
  id        String  @id @default(uuid())
  name      String
  icon      String  @default("📚")
  order     Int     @default(0)
  isPopular Boolean @default(false)

  workbooks Workbook[]
  oxSets    OxQuizSet[]
  vocabSets VocabQuizSet[]
}

model Workbook {
  id              String   @id @default(uuid())
  title           String
  thumbnail       String?
  categoryId      String
  totalQuestions  Int      @default(0)
  questionPerPage Int      @default(12)
  isPopular       Boolean  @default(false)
  createdAt       DateTime @default(now())

  category Category  @relation(fields: [categoryId], references: [id])
  problems Problem[]
  attempts QuizAttempt[]
  reviews  Review[]
}

model Problem {
  id            String  @id @default(uuid())
  workbookId    String
  order         Int
  passageImage  String?
  questionImage String?
  questionText  String?
  choice1       String
  choice2       String
  choice3       String
  choice4       String
  choice5       String?
  answer        Int
  explanation   String?

  workbook Workbook       @relation(fields: [workbookId], references: [id], onDelete: Cascade)
  answers  ProblemAnswer[]
}

model ProblemAnswer {
  id         String  @id @default(uuid())
  attemptId  String
  problemId  String
  selected   Int?
  isCorrect  Boolean @default(false)
  dwellSeconds Int   @default(0)

  attempt QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  problem Problem     @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model OxQuizSet {
  id             String   @id @default(uuid())
  title          String
  thumbnail      String?
  categoryId     String
  difficulty     String   @default("보통")
  totalQuestions Int      @default(0)
  isPopular      Boolean  @default(false)
  createdAt      DateTime @default(now())

  category  Category     @relation(fields: [categoryId], references: [id])
  questions OxQuestion[]
  attempts  QuizAttempt[]
}

model OxQuestion {
  id          String  @id @default(uuid())
  oxQuizSetId String
  order       Int
  section     String?
  question    String
  answer      Boolean
  explanation String?

  oxQuizSet OxQuizSet @relation(fields: [oxQuizSetId], references: [id], onDelete: Cascade)
  answers   OxAnswer[]
}

model OxAnswer {
  id         String   @id @default(uuid())
  attemptId  String
  questionId String
  selected   Boolean?
  isCorrect  Boolean  @default(false)

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question OxQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model VocabQuizSet {
  id             String   @id @default(uuid())
  title          String
  thumbnail      String?
  categoryId     String
  difficulty     String   @default("보통")
  totalQuestions Int      @default(0)
  isPopular      Boolean  @default(false)
  createdAt      DateTime @default(now())

  category  Category        @relation(fields: [categoryId], references: [id])
  questions VocabQuestion[]
  attempts  QuizAttempt[]
}

model VocabQuestion {
  id             String @id @default(uuid())
  vocabQuizSetId String
  order          Int
  word           String
  choice1        String
  choice2        String
  choice3        String
  choice4        String
  answer         Int
  explanation    String?

  vocabQuizSet VocabQuizSet @relation(fields: [vocabQuizSetId], references: [id], onDelete: Cascade)
  answers      VocabAnswer[]
}

model VocabAnswer {
  id         String   @id @default(uuid())
  attemptId  String
  questionId String
  selected   Int?
  isCorrect  Boolean  @default(false)

  attempt  QuizAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question VocabQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id             String   @id @default(uuid())
  userId         String
  quizType       String
  workbookId     String?
  oxQuizSetId    String?
  vocabQuizSetId String?
  score          Int      @default(0)
  totalScore     Int      @default(0)
  timeTaken      Int      @default(0)
  completedAt    DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  workbook     Workbook?     @relation(fields: [workbookId], references: [id])
  oxQuizSet    OxQuizSet?    @relation(fields: [oxQuizSetId], references: [id])
  vocabQuizSet VocabQuizSet? @relation(fields: [vocabQuizSetId], references: [id])

  problemAnswers ProblemAnswer[]
  oxAnswers      OxAnswer[]
  vocabAnswers   VocabAnswer[]
}

model Inquiry {
  id        String   @id @default(uuid())
  userId    String?
  name      String
  email     String
  category  String
  title     String
  content   String
  status    String   @default("접수")
  reply     String?
  createdAt DateTime @default(now())
}

model Bookmark {
  id              String   @id @default(uuid())
  userId          String
  quizType        String
  workbookId      String?
  oxQuizSetId     String?
  vocabQuizSetId  String?
  problemId       String?
  oxQuestionId    String?
  vocabQuestionId String?
  memo            String?  // iPad 메모칸에 타이핑한 텍스트
  drawing         String?  // iPad 필기(손글씨/형광펜) 스냅샷 PNG data URL
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  workbookId String
  rating     Int
  content    String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  workbook Workbook @relation(fields: [workbookId], references: [id])
}
